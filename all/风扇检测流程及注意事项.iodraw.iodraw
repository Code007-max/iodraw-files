        </mxCell>
        <mxCell id="TODJJNPCty3q3b3gkgBC-31" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b&gt;按键检测&lt;/b&gt;&lt;/div&gt;&lt;ol&gt;&lt;li&gt;&lt;b&gt;on\speed按键：按下开机调节风速；数码管显示1、2、3档；风扇各个挡位调节有效&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;time按键：按下红色LED等亮起；请依次按下红色LED从左到右能全部点亮（四颗全亮时再次按下熄灭为止）&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;SW按键： 按下SW按键黄色LED亮起；用万用表测量COM与输出端是否为220V&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;off：关机键； 按下时主板除电源灯外全部熄灭&lt;/b&gt;&lt;/li&gt;&lt;/ol&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;glass=0;strokeWidth=1;shadow=0;align=left;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="60" y="590" width="630" height="110" as="geometry" />
        </mxCell>
        <mxCell id="TODJJNPCty3q3b3gkgBC-34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="WIyWlLk6GJQsqaUBKTNV-1" source="TODJJNPCty3q3b3gkgBC-35" target="TODJJNPCty3q3b3gkgBC-37" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="TODJJNPCty3q3b3gkgBC-35" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; 语音模块检测&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;&lt;b&gt;turn on the fan（打开风扇，数码管显示挡位；风扇该挡位有效）&lt;br&gt;&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;turn off the fan（关闭风扇、风扇关机、除电源外所有灯熄灭）&lt;br&gt;&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;High wind speed（第三档；数码管显示3，风扇该挡位有效）&lt;br&gt;&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Medium wind speed（第二档；数码管显示2，风扇该挡位有效）&lt;br&gt;&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Low wind speed第一档 (数码管显示1，风扇该挡位有效)&lt;br&gt;&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Swing: SW指示灯亮起测量该挡位电压&lt;/b&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="149.38" y="840" width="451.25" height="140" as="geometry" />
        </mxCell>
        <mxCell id="TODJJNPCty3q3b3gkgBC-36" value="&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;智能风扇检测流程&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="299" y="40" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="TODJJNPCty3q3b3gkgBC-37" value="&lt;b&gt;完成&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="315" y="1060" width="120" height="60" as="geometry" />
