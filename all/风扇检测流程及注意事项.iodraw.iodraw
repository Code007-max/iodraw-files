        <mxCell id="TODJJNPCty3q3b3gkgBC-39" value="确保以上4步完整、进行语音检测" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" parent="TODJJNPCty3q3b3gkgBC-30" vertex="1" connectable="0">
