        <mxCell id="TODJJNPCty3q3b3gkgBC-38" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;b&gt;通电前准备工作：&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;检查火线与共线端COM&lt;/li&gt;&lt;li&gt;检查各个插件是否有虚焊、漏焊&lt;/li&gt;&lt;li&gt;重点检查插件电解电容电极方向&lt;/li&gt;&lt;li&gt;安规、压敏、保险等器件焊接检查&lt;/li&gt;&lt;li&gt;测试时保持干燥通风整洁的环境&lt;/li&gt;&lt;li&gt;万用表使用时注意量程&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
