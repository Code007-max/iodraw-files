{"root":{"data":{"id":"dhlwqdissiw0","created":1775461944940,"text":"电饭煲-STM32F103C8T6"},"children":[{"data":{"id":"dhrpo6toiv40","created":1776051385603,"text":"电源"},"children":[{"data":{"id":"dhrpodx0tkw0","created":1776051401043,"text":"AC220V--DC5V; LDO转DC3.3V","priority":1},"children":[{"data":{"id":"dhrpplslnfk0","created":1776051496554,"text":"AC220V连接加热盘供电；\nDC5V给语音模块、数码管、LED、继电器、蜂鸣器供电；\nDC3.3V给主控STM32供电","priority":2},"children":[]}]}]},{"data":{"id":"dhlwr4lui540","created":1775462003898,"text":"语音控制（UART通信）"},"children":[{"data":{"id":"dhro4ie8k5k0","created":1776047022398,"text":"芯片引脚P30： USART1_RX接语音模块TX\n P31： USART1_TX接语音模块RX","priority":1},"children":[]}]},{"data":{"id":"dhlwsp8531c0","created":1775462127146,"text":"继电器控制加热盘"},"children":[{"data":{"id":"dhro7s8wla00","created":1776047278935,"text":"PC15引脚高电平，继电器吸合开始加热；\n低电平继电器断开停止加热","priority":1},"children":[]}]},{"data":{"id":"dhlwrjbh75s0","created":1775462035922,"text":"数码管","priority":null},"children":[{"data":{"id":"dhroamwxctc0","created":1776047502420,"text":"共阳极接法，PB0，PB12，PB13，PB14通过三极管8550接数码管位选1.2.3.4；引脚低电平有效\nPA15,PB3--PB9通过三极管8050接数码管段选A--H; 引脚高电平有效","priority":1},"children":[]}]},{"data":{"id":"dhroe7wpgiw0","created":1776047783211,"text":"功能指示灯"},"children":[{"data":{"id":"dhroih1g6hs0","created":1776048116546,"text":"PB15--三极管8550基极--集电极--LED第1-7组公共端（阳极）；引脚低电平有效\nPA8--三极管8550基极--集电极--LED第8-14组公共端（阳极）；引脚低电平有效","priority":1},"children":[{"data":{"id":"dhrpg00y6000","created":1776050743892,"text":"PB9,PB8,PB7,PB6,PB5,PB4,PB3--三极管8050基极，集电极--LED灯第1-7组；引脚高电平有效","priority":2},"children":[]}]}]},{"data":{"id":"dhlwt80406w0","created":1775462168019,"text":"四个触摸按键"},"children":[{"data":{"id":"dhrpi50nfug0","created":1776050911486,"text":"功能--PA1\n预约--PA2\n设置--PA3\n开关--PA4","priority":1},"children":[{"data":{"id":"dhrpjj7hlmo0","created":1776051020739,"text":"通过内部ADC通道计算触摸后电压变化值","priority":2},"children":[]}]}]},{"data":{"id":"dhlwtglfc480","created":1775462186722,"text":"蜂鸣器报警提示"},"children":[{"data":{"id":"dhrpkub40dc0","created":1776051123266,"text":"PA11--三极管8050基极--集电极--蜂鸣器负极；引脚高电平有效","priority":1},"children":[]}]},{"data":{"id":"dhlx3f6zaaw0","created":1775462967313,"text":"NTC测温分压电路"},"children":[{"data":{"id":"dhrpm6zi1uo0","created":1776051229227,"text":"PA5连接NTC电路分压点，通过内部ADC通道计算电压值，利用查表法对应温度值","priority":1},"children":[]}]},{"data":{"id":"dhrpty0hkmg0","created":1776051836609,"text":"接口定义"},"children":[{"data":{"id":"dhrpu942kbs0","created":1776051860770,"text":"分支主题"},"children":[]}]}]},"template":"right","theme":"classic","version":"1.4.43"}